{
  "version": "2.0.0",
  "description": "Реестр MCP-инструментов EDMS AI Assistant",
  "tools": [
    {
      "name": "get_document",
      "description_ru": "Получить документ по UUID или номеру (DOC-XXXX). Использовать когда пользователь называет конкретный документ. Только чтение — не изменяет данные.",
      "input_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["document_id"],
        "additionalProperties": false,
        "properties": {
          "document_id": {
            "type": "string",
            "description": "UUID документа или номер вида DOC-12345",
            "pattern": "^([0-9a-fA-F]{8}-[0-9a-fA-F]{4}-4[0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}|DOC-\\d{1,10})$"
          },
          "include_history": {
            "type": "boolean",
            "default": false,
            "description": "Включить журнал изменений"
          },
          "include_attachments": {
            "type": "boolean",
            "default": true,
            "description": "Включить список вложений"
          }
        }
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean" },
          "data": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "number": { "type": "string" },
              "title": { "type": "string" },
              "type": { "type": "string" },
              "status": { "type": "string", "enum": ["draft", "review", "approved", "rejected", "signed", "archived"] },
              "created_at": { "type": "string", "format": "date-time" },
              "updated_at": { "type": "string", "format": "date-time" },
              "author": { "type": "object" },
              "assignees": { "type": "array" },
              "attachments": { "type": "array" }
            }
          },
          "error": {
            "type": ["object", "null"],
            "properties": {
              "code": { "type": "string" },
              "message": { "type": "string" }
            }
          }
        }
      },
      "tags": ["read"]
    },
    {
      "name": "search_documents",
      "description_ru": "Поиск документов по фильтрам: тип, статус, автор, дата, текст. Использовать для 'найди договоры', 'покажи документы на согласовании'. Поддерживает пагинацию.",
      "input_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "query": { "type": "string", "maxLength": 500, "description": "Полнотекстовый поиск" },
          "status": {
            "type": "array",
            "items": { "type": "string", "enum": ["draft", "review", "approved", "rejected", "signed", "archived"] }
          },
          "document_type": {
            "type": "array",
            "items": { "type": "string", "enum": ["договор", "приказ", "акт", "счёт", "протокол", "спецификация"] }
          },
          "author_id": { "type": "string" },
          "assignee_id": { "type": "string" },
          "department": { "type": "string" },
          "date_from": { "type": "string", "format": "date-time" },
          "date_to": { "type": "string", "format": "date-time" },
          "page": { "type": "integer", "minimum": 1, "default": 1 },
          "page_size": { "type": "integer", "minimum": 1, "maximum": 100, "default": 20 },
          "sort_by": { "type": "string", "enum": ["created_at", "updated_at", "title", "status"], "default": "updated_at" },
          "sort_order": { "type": "string", "enum": ["asc", "desc"], "default": "desc" }
        }
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean" },
          "data": {
            "type": "object",
            "properties": {
              "items": { "type": "array" },
              "total": { "type": "integer" },
              "page": { "type": "integer" },
              "page_size": { "type": "integer" },
              "total_pages": { "type": "integer" }
            }
          },
          "error": { "type": ["object", "null"] }
        }
      },
      "tags": ["read", "analytics"]
    },
    {
      "name": "create_document",
      "description_ru": "Создать новый документ. НЕОБРАТИМАЯ операция — использовать только по явному запросу пользователя после подтверждения параметров. Обязательно: title и document_type.",
      "input_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["title", "document_type"],
        "additionalProperties": false,
        "properties": {
          "title": { "type": "string", "minLength": 3, "maxLength": 500 },
          "document_type": {
            "type": "string",
            "enum": ["договор", "приказ", "акт", "счёт", "протокол", "спецификация"]
          },
          "content": { "type": "string", "description": "Содержимое/описание" },
          "assignees": { "type": "array", "items": { "type": "string" }, "description": "UUID ответственных" },
          "department": { "type": "string" },
          "due_date": { "type": "string", "format": "date-time" },
          "tags": { "type": "array", "items": { "type": "string" } },
          "metadata": { "type": "object" }
        }
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean" },
          "data": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "number": { "type": "string" },
              "status": { "type": "string" },
              "created_at": { "type": "string", "format": "date-time" }
            }
          },
          "error": { "type": ["object", "null"] }
        }
      },
      "tags": ["write"]
    },
    {
      "name": "update_document_status",
      "description_ru": "Изменить статус документа. НЕОБРАТИМО при rejected/archived — требуется comment и подтверждение пользователя. Требует прав на изменение.",
      "input_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["document_id", "new_status"],
        "additionalProperties": false,
        "properties": {
          "document_id": { "type": "string" },
          "new_status": {
            "type": "string",
            "enum": ["draft", "review", "approved", "rejected", "signed", "archived"]
          },
          "comment": { "type": "string", "maxLength": 2000, "description": "Обязателен при rejected/archived" },
          "notify_assignees": { "type": "boolean", "default": true }
        }
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean" },
          "data": {
            "type": "object",
            "properties": {
              "document_id": { "type": "string" },
              "previous_status": { "type": "string" },
              "new_status": { "type": "string" },
              "changed_at": { "type": "string", "format": "date-time" }
            }
          },
          "error": { "type": ["object", "null"] }
        }
      },
      "tags": ["write", "workflow"]
    },
    {
      "name": "get_document_history",
      "description_ru": "История изменений документа: кто, что, когда. Использовать при вопросах об аудите, хронологии событий, проверке действий конкретного пользователя.",
      "input_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["document_id"],
        "additionalProperties": false,
        "properties": {
          "document_id": { "type": "string" },
          "event_types": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["status_change", "edit", "comment", "assignment", "view", "download"]
            }
          },
          "date_from": { "type": "string", "format": "date-time" },
          "date_to": { "type": "string", "format": "date-time" },
          "limit": { "type": "integer", "minimum": 1, "maximum": 500, "default": 50 }
        }
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean" },
          "data": {
            "type": "object",
            "properties": {
              "document_id": { "type": "string" },
              "events": { "type": "array" },
              "total_events": { "type": "integer" }
            }
          },
          "error": { "type": ["object", "null"] }
        }
      },
      "tags": ["read", "analytics"]
    },
    {
      "name": "assign_document",
      "description_ru": "Назначить ответственных за документ с ролями (reviewer, approver, signer, observer). Использовать при 'передай документ', 'назначь согласующим', 'добавь подписанта'.",
      "input_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["document_id", "assignees"],
        "additionalProperties": false,
        "properties": {
          "document_id": { "type": "string" },
          "assignees": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["user_id", "role"],
              "properties": {
                "user_id": { "type": "string" },
                "role": { "type": "string", "enum": ["reviewer", "approver", "signer", "observer"] },
                "due_date": { "type": "string", "format": "date-time" }
              }
            }
          },
          "replace_existing": { "type": "boolean", "default": false },
          "message": { "type": "string", "maxLength": 1000 }
        }
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean" },
          "data": {
            "type": "object",
            "properties": {
              "document_id": { "type": "string" },
              "assigned": { "type": "array" },
              "notified": { "type": "array" },
              "assigned_at": { "type": "string", "format": "date-time" }
            }
          },
          "error": { "type": ["object", "null"] }
        }
      },
      "tags": ["write", "workflow"]
    },
    {
      "name": "get_analytics",
      "description_ru": "Аналитика документооборота: статистика статусов, нагрузка отделов, просроченные документы, коэффициент одобрения. Использовать при вопросах об отчётах и метриках.",
      "input_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["metric_type"],
        "additionalProperties": false,
        "properties": {
          "metric_type": {
            "type": "string",
            "enum": [
              "status_distribution",
              "volume_by_type",
              "processing_time",
              "workload_by_user",
              "workload_by_department",
              "overdue_documents",
              "approval_rate"
            ]
          },
          "date_from": { "type": "string", "format": "date-time" },
          "date_to": { "type": "string", "format": "date-time" },
          "group_by": { "type": "string", "enum": ["day", "week", "month", "quarter"], "default": "month" },
          "department": { "type": "string" },
          "document_type": { "type": "string" }
        }
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean" },
          "data": {
            "type": "object",
            "properties": {
              "metric_type": { "type": "string" },
              "period": { "type": "object" },
              "results": { "type": "array" },
              "summary": { "type": "object" },
              "generated_at": { "type": "string", "format": "date-time" }
            }
          },
          "error": { "type": ["object", "null"] }
        }
      },
      "tags": ["read", "analytics"]
    },
    {
      "name": "get_workflow_status",
      "description_ru": "Текущий статус рабочего процесса документа: кто ещё не согласовал, ожидающие действия, просрочки, прогресс. Использовать при 'где застрял документ', 'кто не подписал'.",
      "input_schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "required": ["document_id"],
        "additionalProperties": false,
        "properties": {
          "document_id": { "type": "string" },
          "include_completed": { "type": "boolean", "default": false }
        }
      },
      "output_schema": {
        "type": "object",
        "properties": {
          "success": { "type": "boolean" },
          "data": {
            "type": "object",
            "properties": {
              "document_id": { "type": "string" },
              "current_step": { "type": "string" },
              "pending_actions": { "type": "array" },
              "completed_steps": { "type": "array" },
              "overall_progress": { "type": "number", "minimum": 0, "maximum": 100 },
              "estimated_completion": { "type": ["string", "null"], "format": "date-time" }
            }
          },
          "error": { "type": ["object", "null"] }
        }
      },
      "tags": ["read", "workflow"]
    }
  ]
}
