{
  "version": "1.0.0",
  "description": "Реестр MCP инструментов EDMS AI Ассистента",
  "tools": [
    {
      "name": "get_document",
      "category": "documents",
      "description": "Получить полные метаданные документа по UUID",
      "intents": ["get_document", "view_document", "document_info"],
      "required_params": ["document_id"],
      "optional_params": ["token"],
      "complexity": "simple"
    },
    {
      "name": "search_documents",
      "category": "documents",
      "description": "Поиск документов по фильтрам: категория, статус, автор, дата",
      "intents": ["search_documents", "find_documents", "list_documents"],
      "required_params": [],
      "optional_params": ["query", "category", "status", "author_last_name", "date_from", "date_to", "page", "size", "token"],
      "complexity": "simple"
    },
    {
      "name": "get_document_history",
      "category": "documents",
      "description": "История движения документа: кто, что и когда сделал",
      "intents": ["document_history", "document_audit", "document_lifecycle"],
      "required_params": ["document_id"],
      "optional_params": ["token"],
      "complexity": "simple"
    },
    {
      "name": "get_document_versions",
      "category": "documents",
      "description": "Версии документа и изменения между ними",
      "intents": ["compare_versions", "document_changes", "version_history"],
      "required_params": ["document_id"],
      "optional_params": ["token"],
      "complexity": "simple"
    },
    {
      "name": "get_document_statistics",
      "category": "documents",
      "description": "Статистика документов пользователя: исполнение, контроль, авторство",
      "intents": ["statistics", "dashboard", "user_summary"],
      "required_params": [],
      "optional_params": ["token"],
      "complexity": "simple"
    },
    {
      "name": "search_employees",
      "category": "employees",
      "description": "Поиск сотрудников по имени, отделу, должности",
      "intents": ["search_employees", "find_employee", "employee_info"],
      "required_params": [],
      "optional_params": ["last_name", "first_name", "department_name", "post_name", "active_only", "token"],
      "complexity": "simple"
    },
    {
      "name": "get_current_user",
      "category": "employees",
      "description": "Информация о текущем авторизованном пользователе",
      "intents": ["current_user", "my_profile", "who_am_i"],
      "required_params": [],
      "optional_params": ["token"],
      "complexity": "simple"
    },
    {
      "name": "create_task",
      "category": "tasks",
      "description": "Создать поручение по документу с назначением исполнителей",
      "intents": ["create_task", "assign_task", "create_assignment"],
      "required_params": ["document_id", "task_text", "executor_ids"],
      "optional_params": ["deadline", "task_type", "token"],
      "complexity": "medium"
    },
    {
      "name": "create_introduction",
      "category": "tasks",
      "description": "Добавить сотрудников в список ознакомления с документом",
      "intents": ["create_introduction", "familiarization", "send_for_review"],
      "required_params": ["document_id", "employee_ids"],
      "optional_params": ["comment", "token"],
      "complexity": "medium"
    },
    {
      "name": "execute_document_operation",
      "category": "workflow",
      "description": "Выполнить операцию: согласование, подписание, отклонение и др.",
      "intents": ["agree_document", "sign_document", "reject_document", "approve_document", "execute_operation"],
      "required_params": ["document_id", "operation_type"],
      "optional_params": ["comment", "token"],
      "complexity": "medium"
    },
    {
      "name": "start_document_routing",
      "category": "workflow",
      "description": "Запустить маршрут документа (отправить на согласование)",
      "intents": ["start_routing", "send_for_approval", "launch_document"],
      "required_params": ["document_id"],
      "optional_params": ["token"],
      "complexity": "medium"
    },
    {
      "name": "set_document_control",
      "category": "control",
      "description": "Поставить документ на контроль с указанием срока и контролёра",
      "intents": ["set_control", "add_control", "control_document"],
      "required_params": ["document_id", "control_type_id", "deadline"],
      "optional_params": ["controller_id", "token"],
      "complexity": "medium"
    },
    {
      "name": "send_notification",
      "category": "notifications",
      "description": "Отправить уведомление или напоминание сотрудникам по документу",
      "intents": ["send_notification", "remind", "notify_employee"],
      "required_params": ["document_id", "recipient_ids", "message"],
      "optional_params": ["notification_type", "deadline", "token"],
      "complexity": "medium"
    },
    {
      "name": "get_reference_data",
      "category": "references",
      "description": "Справочные данные: типы документов, отделы, виды контроля и др.",
      "intents": ["get_references", "reference_data", "lookup_values"],
      "required_params": ["reference_type"],
      "optional_params": ["search_query", "token"],
      "complexity": "simple"
    },
    {
      "name": "health_check",
      "category": "system",
      "description": "Проверка доступности MCP сервера и EDMS API",
      "intents": ["health_check", "system_status", "connectivity"],
      "required_params": [],
      "optional_params": [],
      "complexity": "simple"
    }
  ]
}
