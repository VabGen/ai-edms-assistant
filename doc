/**
 * Модель для описания ЭЦП документа
 */
public class AttachmentSignature implements Serializable {

    private static final long serialVersionUID = 1L;

    @Schema(description = "Идентификатор ЭЦП")
    private UUID id;

    @Schema(description = "Дата формирования подписи ЭЦП")
    private Instant date;

    @Schema(description = "Признак была ли выполнена проверка валидности ЭЦП")
    private Boolean check;

    @Schema(description = "ЭЦП")
    private Signature sign;

    public AttachmentSignature() {
    }

    public AttachmentSignature(String signData) {
        this.sign = new Signature(signData);
    }

    public AttachmentSignature(UUID id, Instant date, Signature sign) {
        this.id = id;
        this.date = date;
        this.sign = sign;
    }

/**
 * Модель для описания электронно цифровой подпись (ЭЦП).
 */
@JsonIgnoreProperties(ignoreUnknown = true)
public class Signature implements Serializable {

    private static final long serialVersionUID = -8221897274139578590L;

    @Schema(description = "Идентификатор открытого ключа подписавшего")
    private String keyId;
    @Schema(description = "Имя подписавшего")
    private String signer;
    @Schema(description = "Дата/время подписи")
    private Instant signtime;
    @Schema(description = "Тип операции подписания")
    private String operationType;
    @Schema(description = "Значение ЭЦП в исходной системе (если выполнялось заверение третьей стороной)")
    private String origSignature;
    @NotNull
    @Schema(description = "ЭЦП подпись в base64")
    private String data;
    @Schema(description = "Номер сертификата")
    private String certSerial;
    @Schema(description = "ФИО подписавшего")
    private String signerFio;
    @Schema(description = "Дата подписания")
    private Instant signerDate;
    @Schema(description = "Должность подписавшего")
    private String signerPost;
    @Schema(description = "Организация подписавшего")
    private String signerOrg;
    @Schema(description = "Личный номер")
    private String personalNumber;
    @Schema(description = "Издатель сертификата")
    private String issuer;
    private Instant start;
    private Instant end;
    private Integer signCount;

    private String attrCertIssuer;
    private String attrCertIssuerId;
    private String attrOrganizationName;
    private String attrPost;
    private String attrUnp;
    private String attrUnpf;
    private String attrAddress;
    private Instant attrStart;
    private Instant attrEnd;

    public Signature() {
    }

public enum AttachmentDocumentType {

    /** Обычное вложение */
    ATTACHMENT("ATTACHMENT"),
    /** Вложение для печати */
    PRINT_DOCUMENT("PRINT_DOCUMENT"),
    /** Проект решения */
    PROJECT_SOLUTION("PROJECT_SOLUTION"),
    /** Обоснование */
    RATIONALE("RATIONALE"),
    /** Документы по вопросу */
    DOCUMENTS_QUESTION("DOCUMENTS_QUESTION"),
    /** Лист ознакомления */
    INTRODUCTION_LIST("INTRODUCTION_LIST"),
    /** Список согласования */
    AGREEMENT_LIST("AGREEMENT_LIST"),
    /** Решение */
    DECISION("DECISION"),
    RKK("RKK");

    private String name;

    AttachmentDocumentType(String name) {
        this.name = name;
    }

