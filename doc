    private Integer dateRequestCount;
    private Integer executedDateRequestCount;
    @Schema(description = "Бес срока исполнения")
    private Boolean endless;
    private Boolean periodTask = Boolean.FALSE;
    private Integer periodTaskCount;
    private PeriodTaskInterval period;
    private UUID periodTaskParentId;
    private String periodTaskParentOrgId;
    private Instant firstExecution;


    public TaskDto() {
    }

