/**
 * DTO Модель для описания сроков хранения
 */
public class StoragePeriodDto {

    @Schema(description = "Идентификатор срока хранения")
    private UUID id;

    @JsonIgnore
    private String organizationId;

    @Schema(description = "Наименование срока хранения")
    private String name;

    private GroupsByStoragePeriod groupByStoragePeriod;

    @Schema(description = "Признак активен ли срок хранения")
    private Boolean active;

    private Instant createDate;

    @Schema(description = "Признак - по личному составу")
    private boolean byStaff;

    @Schema(description = "Срок хранения дела в годах")
    private Integer storageYears;

    @Schema(description = "Добавочный текст к количеству лет хранения")
    private YearPostfix yearPostfix;

    @Schema(description = "Другой тип хранения")
    private StoragePeriodType storagePeriodType;

    public StoragePeriodDto() {
    }

public enum GroupsByStoragePeriod {

    S_T_UP_TO_10_Y, // Время хранения до 10 лет
    S_T_OVER_10_Y,  // Время хранения свыше 10 лет
    P_S,            // Постоянное хранение
//    BY_STAFF        // По личному составу

}

public enum YearPostfix {

    YEAR("год"),
    YEARS("года"),
    YEARS_PLURAL("лет");

    private final String name;

    YearPostfix(String name) {
        this.name = name;
    }

    public String getName() {
        return name;
    }

    @Override
    public String toString() {
        return name;
    }

}

public enum StoragePeriodType {

    NUMERIC("Числовой"),
    PERMANENT("Постоянно"),
    UNTIL_NEEDED("До минования надобности"),
    UNTIL_REPLACED("До замены новыми");

    private final String name;

    StoragePeriodType(String name) {
        this.name = name;
    }

    public String getName() {
        return name;
    }

    @Override
    public String toString() {
        return name;
    }

}

