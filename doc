public enum JobStatus {
    NEW,
    AWAITING_CONVERSION,
    READY, // Оправлено на формирование вн. описи и описи документов
    IN_WORK_CONVERSION, // Формируется вн. опись и опись документов
    COMPLETED, // Сформирована вн. опись и опись документов
    SIGNED, // Подписано
    DISPATCH, // Оправлено на отправку
    IN_WORK_DISPATCH, // В процессе отправки
    SENT, // Оправлено
    ERROR_CONVERSION,
    ERROR_DISPATCH
}

