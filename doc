    @Schema(description = "Документ")
    private DocumentDto document;

    @Schema(description = "Признак стоит ли поручение на доработке")
    private Boolean revision;

    @Schema(description = "Количество исполнителей")
    private Integer countExec;

    @Schema(description = "Рег номер документа")
    private String documentRegNum;

    private String periodTaskParentNumber;
    private String parentTaskNumber;

    @Schema(description = "Количество исполнителей которые исполнели")
