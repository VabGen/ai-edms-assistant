public enum PeriodTaskInterval {

    WEEK("Неделя"),
    MONTH("Месяц"),
    THREE_MONTHS("Квартал"),
    SIX_MONTHS("Полгода"),
    YEAR("Год");

    String historyName;

    PeriodTaskInterval(String historyName) {
        this.historyName = historyName;
    }

    public String getHistoryName() {
        return historyName;
    }

}

