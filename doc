@Schema(description = "Перечисление для описания типов процесса")
public enum ProcessType {

    /** создание */
    NEW("NEW",DocumentStatus.NEW,DocumentStatus.NEW),
    /** согласование */
    AGREEMENT("AGREEMENT",DocumentStatus.AGREEMENT,DocumentStatus.AGREED),
    /** подписание */
    SIGNING("SIGNING",DocumentStatus.SIGNING,DocumentStatus.SIGNED),
    /** утверждение */
    STATEMENT("STATEMENT",DocumentStatus.STATEMENT,DocumentStatus.APPROVED),
    /** регистрация  */
    REGISTRATION("REGISTRATION",DocumentStatus.REGISTRATION,DocumentStatus.REGISTERED),
    /** рассмотрение */
    REVIEW("REVIEW",DocumentStatus.REVIEW,DocumentStatus.REVIEWED),
    /** исполнение */
    EXECUTION("EXECUTION",DocumentStatus.EXECUTION,DocumentStatus.EXECUTED),
    /** Отправка */
    DISPATCH("DISPATCH",DocumentStatus.DISPATCH,DocumentStatus.SENT),
    /** подготовка */
    PREPARATION("PREPARATION",DocumentStatus.PREPARATION,DocumentStatus.PREPARATION),
    /** оформление */
    PAPERWORK("PAPERWORK",DocumentStatus.PAPERWORK,DocumentStatus.FORMALIZED),
    /** одобрение */
    ACCEPTANCE("ACCEPTANCE",DocumentStatus.ACCEPTANCE,DocumentStatus.ACCEPTED),
    /** Исполнение договора */
    CONTRACT_EXECUTION("CONTRACT_EXECUTION",DocumentStatus.CONTRACT_EXECUTION,DocumentStatus.CONTRACT_CLOSED);

    @NotNull
    private String name;
    private String historyName;
    private String historyStepStartName;
    private String historyStepEndName;
    private String actionName;
    private DocumentStatus start;
    private DocumentStatus end;

    static {
        NEW.historyName = "Новый";
        AGREEMENT.historyName = "Согласование";
        SIGNING.historyName = "Подписание";
        STATEMENT.historyName = "Утверждение";
        REGISTRATION.historyName = "Регистрация";
        REVIEW.historyName = "Рассмотрение";
        EXECUTION.historyName = "Исполнение";
        DISPATCH.historyName = "Отправка";
        PREPARATION.historyName = "Подготовка";
        PAPERWORK.historyName = "Оформление";
        ACCEPTANCE.historyName = "Одобрение";
        CONTRACT_EXECUTION.historyName = "Исполнение договора";

        NEW.historyStepStartName = "Этап Новый начат";
        AGREEMENT.historyStepStartName = "Отправлен на согласование: ";
        SIGNING.historyStepStartName = "Отправлен на подписание: ";
        STATEMENT.historyStepStartName = "Отправлен на утверждение: ";
        REGISTRATION.historyStepStartName = "Отправлен на регистрацию: ";
        REVIEW.historyStepStartName = "Отправлен на рассмотрение: ";
        EXECUTION.historyStepStartName = "Отправлен на исполнение";
        DISPATCH.historyStepStartName = "Передан на отправку: ";
        PREPARATION.historyStepStartName = "Отправлен на подготовку: ";
        PAPERWORK.historyStepStartName = "Отправлен на оформление: ";
        ACCEPTANCE.historyStepStartName = "Отправлен на одобрение: ";
        CONTRACT_EXECUTION.historyStepStartName = "Отправлен на исполнение договора: ";

        NEW.historyStepEndName = "Этап Новый завершен";
        AGREEMENT.historyStepEndName = "Согласован";
        SIGNING.historyStepEndName = "Подписан";
        STATEMENT.historyStepEndName = "Утвержден";
        REGISTRATION.historyStepEndName = "Этап Регистрация завершен";
        REVIEW.historyStepEndName = "Рассмотрен";
        EXECUTION.historyStepEndName = "Исполнен";
        DISPATCH.historyStepEndName = "Отправлен";
        PREPARATION.historyStepEndName = "Этап Подготовка завершен";
        PAPERWORK.historyStepEndName = "Этап Оформление завершен";
        ACCEPTANCE.historyStepEndName = "Этап Одобрение завершен";
        CONTRACT_EXECUTION.historyStepEndName = "Этап Исполнение договора завершен";

        REVIEW.actionName = "Рассмотрено: ";
        REGISTRATION.actionName = "Зарегистрирован";
        STATEMENT.actionName = "Утвержден: ";
        SIGNING.actionName = "Подписан: ";
        DISPATCH.actionName = "Выполнил отправку";
        AGREEMENT.actionName = "Согласовано: ";
        PREPARATION.actionName = "Подготовлен: ";
        PAPERWORK.actionName = "Оформлен: ";
        ACCEPTANCE.actionName = "Одобрен: ";
        CONTRACT_EXECUTION.actionName = "Закрыт: ";
    }

    ProcessType(String name, DocumentStatus start, DocumentStatus end) {
        this.name = name;
        this.start = start;
        this.end = end;
    }

