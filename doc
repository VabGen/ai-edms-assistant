/**
 * DTO Модель для описания документа
 */
public class DocumentDto {

    @Schema(description = "Идентификатор документа")
    private UUID id;

    private String organizationId;

    private DocumentCategoryConstants docCategoryConstant;

    @Schema(description = "Дата создания")
    private Instant createDate;

    @Schema(description = "Кол-во дней исполнения")
    private Integer daysExecution;

    private String profileName;

    @Schema(description = "Список обязательных полей")
    private List<RequiredField> requiredField;

    @Schema(description = "Автор документа")
    private UserInfoDto author;

    private UserInfoDto responsibleExecutor;

    private DocumentStatus status;
    private DocumentUserColorDto color;

    private DocumentStatus prevStatus;

    @Schema(description = "Регистрационный номер документа")
    private String regNumber;

    @Schema(description = "Зарезервированный регистрационный номер документа")
    private String reservedRegNumber;

    @Schema(description = "Дата резервирования регистрационного номера документа")
    private Instant reservedRegDate;

    @Schema(description = "Дата регистрации документа")
    private Instant regDate;

    @Schema(description = "Признак документа с грифом ДСП. По умолчанию признак снят.")
    private Boolean dspFlag;

    @Schema(description = "Кол-во страниц документа")
    private Long pages;

    @Schema(description = "Номер экземпляра")
    private Integer exemplarNumber;

    @Schema(description = "Краткое содержание, может выбираться из справочника кратких содержаний")
    private String shortSummary;

    @Schema(description = "Текст документа")
    private String summary;

    @Schema(description = "Наименование корреспондента")
    private String correspondentName;

    @Schema(description = "Есть ли в документе адресаты")
    private Boolean recipients;

    @Schema(description = "Идентификатор профиля документа")
    private UUID profileId;

    @Schema(description = "Идентификатор версии документа")
    private UUID documentVersionId;

    @Schema(description = "Признак стоит ли документ на контроле")
    private Boolean controlFlag;

    @Schema(description = "Метка снятия с контроля")
    private Boolean removeControl;

    @Schema(description = "Идентификатор журнала регистрации")
    private UUID journalId;

    @Schema(description = "Вид документа")
    private DocumentTypeDto documentType;

    @Schema(description = "Идентификатор вида документа")
    private Long documentTypeId;

    private UUID refDocId;
    private String refDocOrgId;

    private Boolean versionFlag;

    @Schema(description = "Формула рег. номера")
    private List<String> formula;

    @Schema(description = "Список поручений")
    private List<TaskDto> taskList;

    @Schema(description = "Способ получения документа")
    private DeliveryMethodDto deliveryMethod;
    private Long deliveryMethodId;

    @Schema(description = "Идентификатор корреспондент")
    private UUID correspondentId;

    @Schema(description = "Исходящий регистрационный номер")
    private String outRegNumber;

    @Schema(description = "Исходящая дата регистрации документа")
    private Instant outRegDate;

    @Schema(description = "Кол-во листов приложений к документу")
    private String additionalPages;

    @Schema(description = "Кол-во экземлпяров документа")
    private Long exemplarCount;

    @Schema(description = "Ид инвест программы")
    private UUID investProgramId;

    @Schema(description = "Инвест программа")
    private InvestmentProgramDto investmentProgram;

    /** Получен в ответ на */
    @Schema(description = "Идентификатор документа который получен в ответ на другой документ")
    private UUID receivedDocId;

    /** Создан в ответ на */
    @Schema(description = "Идентификатор документа создан в ответ на другой документ")
    private UUID answerDocId;

    @Schema(description = "Документ который получен в ответ на другой документ")
    private DocumentDto receivedAsAnswerByDoc;

    @Schema(description = "Документ который создан в ответ на другой документ")
    private DocumentDto createAsAnswerByDoc;

    @Schema(description = "Версия документа")
    private DocumentVersionDto version;

    @Schema(description = "Процесс документа")
    private DocumentProcessDto process;

    private UUID processId;

    @Schema(description = "Список вложений к документу")
    private List<AttachmentDocumentDto> attachmentDocument;

    @Schema(description = "Корреспондент")
    private DocumentRecipientDto correspondent;

    @Schema(description = "Список адресатов")
    private List<DocumentRecipientDto> recipientList;

    @Schema(description = "Контроль")
    private ControlDto control;
    private DocumentCreateType createType;

    @Schema(description = "Дата проведения совещания")
    private Instant dateMeeting;

    @Schema(description = "Дата проведения заседания")
    private Instant dateMeetingQuestion;

    @Schema(description = "Время начала совещания")
    private Instant startMeeting;

    @Schema(description = "Время начала совещания")
    private Instant endMeeting;

    @Schema(description = "Место проведения совещания")
    private String placeMeeting;

    @Schema(description = "Председатель")
    private UserInfoDto chairperson;

    @Schema(description = "Секретарь")
    private UserInfoDto secretary;

    @Schema(description = "Внешние приглашенные")
    private String externalInvitees;

    @Schema(description = "Количество внутренних приглашенных")
    private Integer inviteesCount;

    @Schema(description = "Признак дополнения к повестке вопросов")
    private Boolean addition = false;

    @Schema(description = "Идентификатор документа дополнительного заседания по вопросам")
    private UUID additionMeetingQuestionId;

    @JsonIgnore
    @Schema(description = "Идентификатор организации документа дополнительного заседания по вопросам")
    private String additionMeetingQuestionOrgId;

    @Schema(description = "Документ дополнительного заседания по вопросам")
    private DocumentDto additionMeetingQuestion;

    @Schema(description = "Форма проведения заседания")
    private FormMeetingQuestionType formMeetingType;

    @Schema(description = "Содержит информацию о порядковом номере вопроса в повестке дня")
    private Integer numberQuestion;

    @Schema(description = "Список вопросов")
    private List<DocumentQuestionDto> documentQuestions;

    @Schema(description = "Отметка о наличии вопросов в повестке")
    private Boolean hasQuestion;

    @Schema(description = "Идентификатор документа заседание по вопросам")
    private UUID documentMeetingQuestionId;

    @Schema(description = "Идентификатор организации документа заседание по вопросам")
    private String documentMeetingQuestionOrgId;

    @Schema(description = "Документ заседание по вопросам")
    private DocumentDto documentMeetingQuestion;

    @Schema(description = "Лист 'Кто подписал'")
    private List<MiniUserInfoDto> whoAddressed;

    private Integer writeOffAffairCount = 0;

    /**
     * Кол-во пред добавленных дел в документ
     */
    private Integer preAffairCount = 0;

    private String inDocSigners;
    private String countryName;
    private UUID countryId;

    private List<IntroductionDto> introduction;
    private Integer introductionCount;
    private Integer introductionCompleteCount;

    private AutoControl autoControl;

    private Boolean skipRegistration = Boolean.FALSE;

    /* Поля для обращений */
    private DocumentAppealDto documentAppeal;

    @Schema(description = "Список ответственных за подготовку материалов")
    private List<DocumentResponsibleExecutorDto> responsibleExecutors;

    @Schema(description = "Присутствие ответственных за подготовку материалов")
    private Boolean hasResponsibleExecutor;

    @Schema(description = "количество ответственных за подготовку материалов")
    private Integer responsibleExecutorsCount;

    @Schema(description = "Кол-во связей документа")
    private Integer documentLinksCount;

    @Schema(description = "Дата проведения заседания для документа по вопросу")
    private Instant dateQuestion;

    @Schema(description = "Комментарии для руководителя")
    private String commentQuestion;

    private UserInfoDto initiator;

    @Schema(description = "Список предварительных номенклатур")
    private List<DocumentPreNomenclatureDto> preNomenclatureAffairs;

    private RegistrationJournalDto registrationJournal;

    @Schema(description = "Кем подписан (для внутреннего и исходя-щего документа)")
    private UserInfoDto whoSigned;

    /**
     * Кол-во сотрудников для оповещения в повестке заседания
     */
    private Integer meetingQuestionNotifyCount;
    private DocumentUserPropsDto userProps;

    private String note;

    @Schema(description = "Включение грифа доступа")
    private Boolean enableAccessGrief = Boolean.FALSE;

    @Schema(description = "Идентификатор грифа доступа")
    private UUID accessGriefId;

    @Schema(description = "Гриф доступа")
    private AccessGriefDto accessGrief;

    private Boolean autoRouting;
    private BigDecimal contractSum;
    private Instant contractDurationStart;

    private CurrencyDto currency;
    private UUID currencyId;
    private Instant contractSigningDate;
    private Instant contractStartDate;
    private Instant contractDurationEnd;
    private Boolean contractAgreement;
    private Boolean contractAutoProlongation;
    private Boolean contractTypical;
    private String contractNumber;
    private Instant contractDate;
    private Integer countTask = 0;
    private Integer taskProjectCount = 0;
    private Integer completedTaskCount = 0;
    private DocumentInventoryDataDto documentInventoryData;
    private String currentBpmnTaskName;

    private DocumentFormDefinitionDto documentFormDefinition;

    @Schema(description = "Пользовательские поля документа")
    private Map<String, Object> customFields;

    private List<AdditionalDocumentDto> additionalDocuments;

    private UUID documentFormId;

    @Schema(description = "Номер журнала регистрации при регистрации документа")
    private Long journalNumber;

    public DocumentDto() {
    }

/**
 * Констатнты типов документов, которые используются в коде для обработки. Используются в справочнике <i>Типов документов</i>,
 * <i>Шаблонов печатных форм</i>. <br>
 * Соответствует ENUM <b>document_category_constants</b> в БД. Данный ENUM используется в таблице <b>document_category</b>.
 */
public enum DocumentCategoryConstants {

    /**
     * внутрений
     */
    INTERN("Внутренний документ", eu.iba.edms.report.common.DocumentCategoryConstants.INTERN),

    /**
     * входящий
     */
    INCOMING("Входящий документ", eu.iba.edms.report.common.DocumentCategoryConstants.INCOMING),

    /**
     * исходящий
     */
    OUTGOING("Исходящий документ", eu.iba.edms.report.common.DocumentCategoryConstants.OUTGOING),

    /**
     * совещание
     */
    MEETING("Совещание", eu.iba.edms.report.common.DocumentCategoryConstants.MEETING),

    /**
     * вопрос повестки
     */
    QUESTION("Вопрос повестки", eu.iba.edms.report.common.DocumentCategoryConstants.QUESTION),

    /**
     * заседание по вопросам
     */
    MEETING_QUESTION("Повестка заседания", eu.iba.edms.report.common.DocumentCategoryConstants.MEETING_QUESTION),

    /**
     * Обращения
     */
    APPEAL("Обращение", eu.iba.edms.report.common.DocumentCategoryConstants.APPEAL),

    /**
     * Договор
     */
    CONTRACT("Договор",eu.iba.edms.report.common.DocumentCategoryConstants.CONTRACT),

    CUSTOM("Пользовательский документ", eu.iba.edms.report.common.DocumentCategoryConstants.CUSTOM);

    private final String docCategoryConstant;
    private final eu.iba.edms.report.common.DocumentCategoryConstants reportCategoryConstant;

    DocumentCategoryConstants(String docCategoryConstant, eu.iba.edms.report.common.DocumentCategoryConstants reportCategoryConstant) {
        this.docCategoryConstant = docCategoryConstant;
        this.reportCategoryConstant = reportCategoryConstant;
    }

public enum RequiredField {

    /** файл(ы) вложения */
    ATTACHMENT,

    /** исх.№ организации-корреспондента */
    OUT_CORRESPONDENT_ORG_NUM,

    /** дата документа организации-корреспондента */
    OUT_CORRESPONDENT_ORG_DATE,

    /** наименование организации-корреспондента */
    OUT_CORRESPONDENT_NAME,

    /** кем подписан */
    DOC_SIGNERS,

    /** наименование адресата */
    RECIPIENT_NAME,

    /** предвыбранные дела */
    AFFAIRS,

    /** контрагенты в договорах*/
    CONTRACT_CORRESPONDENT;

}

/**
 * Внедряемая DTO сущность, которая хранит информацию о работнкике который создал: документ, поручение, контроль, ознакомление.<br>
 * Если документ получен от другой организации средствами системы и документ создан автоматически,<br>
 * то вносится текст <b>"АИС МВ"</b>.
 * Автор является отдельной сущностью для того, что бы при смене фамилии или департамента или других реквизитов,
 * в документах данные об авторе оставались не изменными.
 */
public class UserInfoDto implements NamedUser, Serializable {

    private static final long serialVersionUID = -1L;

    @Schema(description = "Имя сотрудника")
    private String firstName;

    @Schema(description = "Фамилия сотрудника")
    private String lastName;

    @Schema(description = "Отчество сотрудника")
    private String middleName;

    @Schema(description = "Наименование должность сотрудника")
    private String authorPost;

    @Schema(description = "Наименование департамента сотрудника")
    private String authorDepartmentName;

    @Schema(description = "Департамент сотрудника")
    private DepartmentDto authorDepartment;

    @Schema(description = "Идентификатор департамента сотрудника")
    private UUID authorDepartmentId;

    @JsonIgnore
    private String authorDepartmentOrgId;

    @Schema(description = "Сотрудник")
    private EmployeeDto employee;

    @Schema(description = "Идентификатор сотрудник")
    private UUID employeeId;

    @JsonIgnore
    private String employeeOrgId;

    public UserInfoDto() {
    }

    public UserInfoDto(String firstName, String lastName, String middleName, String authorPost,
                       String authorDepartmentName, DepartmentDto authorDepartment, UUID authorDepartmentId,
                       String authorDepartmentOrgId, EmployeeDto employee, UUID employeeId, String employeeOrgId) {
        this.firstName = firstName;
        this.lastName = lastName;
        this.middleName = middleName;
        this.authorPost = authorPost;
        this.authorDepartmentName = authorDepartmentName;
        this.authorDepartment = authorDepartment;
        this.authorDepartmentId = authorDepartmentId;
        this.authorDepartmentOrgId = authorDepartmentOrgId;
        this.employee = employee;
        this.employeeId = employeeId;
        this.employeeOrgId = employeeOrgId;
    }

/**
 * DTO Модель для описания департамента
 */
@JsonIgnoreProperties(ignoreUnknown = true)
public class DepartmentDto implements Serializable {

    private static final long serialVersionUID = 1L;

    @NotNull(groups = {ChangeDepartment.class})
    @Schema(description = "Идентификатор департамента/подразделения")
    private UUID id;

    @JsonIgnore
    private String organizationId;

    @JsonIgnore
    private String externalId;

    @NotNull(groups = {CreateDepartment.class, ChangeDepartment.class})
    @Schema(description = "Наименование департамента/подразделения")
    private String name;

    @Schema(description = "Номер департамента/подразделения в номенклатуре дел")
    private String number;

    @Schema(description = "Идентификатор родительского департамента/подразделения")
    private UUID parentDepartmentId;

    @JsonIgnore
    @Schema(description = "Идентификатор организации родительского департамента/подразделения")
    private String parentDepartmentOrgId;

    @Schema(description = "Родительский департамент/подразделение")
    private DepartmentDto parentDepartment;

    @Schema(description = "Номер по классификатору")
    private String rank;

    @Schema(description = "Код департамента/подразделения")
    private String departmentCode;

    @Schema(description = "Телефон")
    private String phone;

    @Schema(description = "Email")
    private String email;

    @Schema(description = "Адрес")
    private String address;

    @Schema(description = "Площадка")
    private String room;

    @Schema(description = "Идентификатор руководителя департамента/подразделения")
    private UUID leaderId;

    @Schema(description = "Руководитель департамента/подразделения")
    private EmployeeDto leader;

    @JsonIgnore
    private String leaderOrgId;

    @Schema(description = "Список сотрудников департамента/подразделения, поле игнорируется при обновлении записи")
    private List<EmployeeDto> employees;

    @Schema(description = "Список заместителей руководителя департамента/подразделения")
    private List<DeputyLeaderDepartmentDto> deputyLeaders;

    @Schema(description = "Список ответственных по номенклатуре")
    private List<DepartmentEmployeeNomenclatureDto> employeeNomenclatures;

    private Instant createDate;
    private transient Boolean currentUserLeader;

    @Schema(description = "Порядок сортировки")
    private Integer order = 0;

    public static interface CreateDepartment {
    }

    public static interface ChangeDepartment {
    }

    public DepartmentDto() {
    }

public class DeputyLeaderDepartmentDto {

    private UUID id;
    @JsonIgnore
    private String organizationId;
    private UUID departmentId;
    @JsonIgnore
    private String departmentOrgId;
    private DepartmentDto department;
    private UUID employeeId;
    @JsonIgnore
    private String employeeOrgId;
    private EmployeeDto employee;

    public DeputyLeaderDepartmentDto() {
    }

public class DepartmentEmployeeNomenclatureDto {

    private UUID id;

    private UUID departmentId;

    @JsonIgnore
    private String departmentOrgId;

    private DepartmentDto department;

    private UUID employeeId;

    private EmployeeDto employee;

    public DepartmentEmployeeNomenclatureDto() {
    }

/**
 * DTO Модель для описания сотрудника
 */
@JsonIgnoreProperties(ignoreUnknown = true)
public class EmployeeDto implements Serializable, NamedUser {

    private static final long serialVersionUID = 1L;

    @Schema(description = "Идентификатор сотрудника")
    private UUID id;
    @Schema(description = "Идентификатор аккаунта сотрудника")
    private String uId;
    @JsonIgnore
    private String externalId;
    @Schema(description = "Персональный номер сотрудника")
    private String personalNumber;
    @Schema(description = "Имя сотрудника")
    private String firstName;
    @Schema(description = "Фамилия сотрудника")
    private String lastName;
    @Schema(description = "Отчество сотрудника")
    private String middleName;
    @Schema(description = "Признак уволен ли сотрудник")
    private Boolean fired;
    @Schema(description = "Признак активен ли сотрудник")
    private Boolean active;
    private transient String organizationId;
    @Schema(description = "ФИО сотрудника")
    private String fullPostName;
    @Schema(description = "Идентификатор должности")
    private Long postId;
    @Schema(description = "Должность сотрудника")
    private PostDto post;
    @JsonIgnore
    private String departmentOrgId;
    @Schema(description = "Идентификатор департамента в котором работает сотрудник")
    private UUID departmentId;
    @Schema(description = "Департамент сотрудника")
    private DepartmentDto department;
    @Schema(description = "Организация сотрудника")
    private OrgDto org;

    @Schema(description = "Адрес")
    private String address;
    @Schema(description = "Площадка")
    private String place;
    @Schema(description = "URL")
    private String url;
    @Schema(description = "E-mail")
    private String email;
    @Schema(description = "Телефон")
    private String phone;
    @Schema(description = "LDAP Имя")
    private String ldapName;

    @Schema(description = "Я вляется ИО")
    private Boolean io;
    @Schema(description = "Присутствуют ИО")
    private Boolean haveIo;
    @Schema(description = "Уведомлять ли сотрудника сообщениями на почту")
    private Boolean notify;
    private Instant createDate;
    @Schema(description = "Дата последней ручной загрузки аватара")
    private Instant lastManualAvatarUploadDate;
    private EmployeeCreateType createType;
    private String sid;
    private Boolean currentUserLeader;
    private List<EmployeeServiceImpl.EmployeeBlockField> blockedFields;
    @Schema(description = "Порядок сортировки")
    private Integer order = 0;

    public EmployeeDto() {
    }

/**
 * DTO Модель для описания организации
 */
public class OrgDto implements Serializable {

    private static final long serialVersionUID = 1L;

    @Schema(description = "Идентификатор организации")
    private String id;

    @Schema(description = "Наименование организации")
    private String name;

    @Schema(description = "Текущее кол-во активных учетных записей в СЭД")
    private Integer currentCount;

    @Schema(description = "Максимально кол-во активных учетных записей")
    private Integer maxCount;

    @Schema(description = "Признак активена ли организация")
    private Boolean active;

    @Schema(description = "Список сотрудников организации")
    private List<EmployeeDto> employees;

    public OrgDto() {
    }

public enum EmployeeCreateType {

    MANUAL,
    LDAP;

}

@Schema(description = "Перечисление для описания статусов документов")
public enum DocumentStatus {

    /**
     * Черновик
     */
    DRAFT("Черновик"),

    /**
     * Новый
     */
    NEW("Новый"),

    /**
     * Утверждение
     */
    STATEMENT("На утверждении"),

    /**
     * Утвержден
     */
    APPROVED("Утвержден"),

    /**
     * Подписание
     */
    SIGNING("На подписании"),

    /**
     * Подписан
     */
    SIGNED("Подписан"),

    /**
     * Согласование
     */
    AGREEMENT("На согласовании"),

    /**
     * Согласован
     */
    AGREED("Согласован"),

    /*INTERNAL_AGREEMENT("На согласовании (Внеш.)"),
    INTERNAL_AGREEMENT_SENT("На согласовании (Внеш.) - Отправлен"),
    INTERNAL_AGREED("Согласован (Внеш.)"),*/

    /**
     * Рассмотрение
     */
    REVIEW("На рассмотрении"),

    /**
     * Расммотрен
     */
    REVIEWED("Рассмотрен"),

    /**
     * Регистрация
     */
    REGISTRATION("На регистрации"),

    /**
     * Зарегистрирован
     */
    REGISTERED("Зарегистрирован"),

    /**
     * Исполнение
     */
    EXECUTION("На исполнении"),

    /**
     * Исполнен
     */
    EXECUTED("Исполнен"),

    /**
     * Отправка
     */
    DISPATCH("На отправке"),

    /**
     * Отправлен
     */
    SENT("Отправлен"),

    /**
     * Отклонен
