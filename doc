    private Integer pagesCount;

    @Schema(description = "Начальная страница")
    private Integer startPage;

    @Schema(description = "Конечная страница")
    private Integer endPage;

    @Schema(description = "Размер документа")
    private Long documentSize;

    private UserInfoDto author;

    @Schema(description = "Дата создания основного документа")
    private Instant docCreateDate;

    @Schema(description = "Дата создания")
    private Instant createDate;

    @Schema(description = "Дата изменения")
    private Instant modifyDate;

    @Schema(description = "Идентификатор основного документа")
    private UUID documentId;

    @JsonIgnore
    private String documentOrganizationId;

    @Schema(description = "Основной документ")
    private DocumentDto document;

    @Schema(description = "Вложения")
    private List<MiniDocumentAttachmentDto> attachments = new ArrayList<>();

    @Schema(description = "Номенклатурное дело")
    private NomenclatureAffairDto nomenclatureAffair;

    @Schema(description = "Идентификатор номенклатурного дела")
    private UUID nomenclatureAffairId;

    @JsonIgnore
    private String nomenclatureAffairOrganizationId;

    @Schema(description = "Опись документа")
    private DocumentInventoryDataDto documentInventory;

    @Schema(description = "Вид документа (Унифицированный код из окрб 010-95 таблица 1)")
    private String objectType;

    @Schema(description = "Дата подписания или утверждения документа")
    private Instant sourceApproveTs;

    @Schema(description = "Список ЭЦП вложения")
    private List<AttachmentSignature> signs;

    @Schema(description = "Числовое значение номера тома (части дела)")
    private Integer numberPagesPerVolume;

    @Schema(description = "контрольная характеристика файлов документа")
    private String hashED;

    @Schema(description = "Номер журнала регистрации при регистрации документа")
    private Long journalNumber;

    @Schema(description = "Дата регистрации без времени")
    private LocalDate regDateWithoutTime;

    @Schema(description = "Удалено на статусе архивное и должно отображаться в списке")
    private boolean deleted;

    @Schema(description = "Количество вложений")
    private int attachmentCount;

    public UUID getId() {
        return id;
    }

    public MiniDocumentDto setId(UUID id) {
        this.id = id;
        return this;
    }

@Schema(description = "DTO для вложений мини-документа")
public class MiniDocumentAttachmentDto implements Serializable {

    private static final long serialVersionUID = 1L;

    @Schema(description = "Идентификатор вложения")
    private UUID id;

    @Schema(description = "Идентификатор мини-документа")
    private UUID miniDocumentId;

    @JsonIgnore
    @Schema(description = "Идентификатор организации мини-документа")
    private String miniDocumentOrganizationId;

    @Schema(description = "Тип вложения")
    private AttachmentDocumentType type;

    private AttachmentDto attachment;

    private ContentType contentType;

    @Schema(description = "Дата загрузки")
    private Instant uploadDate;

    @Schema(description = "Список ЭЦП вложения")
    private List<AttachmentSignature> signs;

    @Schema(description = "Id вида дополнительного документа")
    private UUID additionalDocumentTypeId;

    @Schema(description = "Вид дополнительного документа")
    private AdditionalDocumentTypeDto additionalDocumentType;

    private UUID docAttachmentId;

    private UUID additionalDocAttachmentId;

    public UUID getId() {
        return id;
    }

    public MiniDocumentAttachmentDto setId(UUID id) {
        this.id = id;
        return this;
    }

public enum ContentType {

    /** Вложение формата doc */
    DOC("DOC"),
    /** Вложение формата docx */
    DOCX("DOCX"),
    /** Вложение формата tif */
    TIF("TIF"),
    /** Вложение формата tiff */
    TIFF("TIFF"),
    /** Вложение формата jpg */
    JPG("JPG"),
    /** Вложение формата jpeg */
    JPEG("JPEG"),
    /** Вложение формата bmp */
    BMP("BMP"),
    /** Вложение формата pdf */
    PDF("PDF"),
    /** Вложение формата gif */
    GIF("GIF"),
    /** Вложение формата png */
    PNG("PNG"),
    /** Вложение другого формата */
    OTHER("OTHER");

    private String name;

    ContentType(String name) {
        this.name = name;
    }

    public String getName() {
        return name;
    }

    public static ContentType RecognitionFileTypestoContentType(RecognitionFileTypes value) {
        return ContentType.valueOf(value.getName());
    }
}

