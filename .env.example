# ═══════════════════════════════════════════════════════════
# EDMS AI Assistant — Environment Configuration
# ═══════════════════════════════════════════════════════════

# ── Application ─────────────────────────────────────────────
ENVIRONMENT=production
API_PORT=8002
JWT_SECRET_KEY=change-me-to-strong-random-secret-32chars

# ── EDMS ────────────────────────────────────────────────────
EDMS_API_URL=http://localhost:8098
EDMS_API_KEY=
EDMS_TIMEOUT=30

# ── LLM — лёгкая модель (Ollama, для простых задач) ─────────
LLM_LIGHT_URL=http://localhost:11434/v1
LLM_LIGHT_MODEL=llama3.2:3b

# ── LLM — тяжёлая модель (для сложных задач) ────────────────
LLM_HEAVY_URL=http://localhost:11434/v1
LLM_HEAVY_MODEL=gpt-oss:120b-cloud
LLM_API_KEY=ollama

# ── Embedding ────────────────────────────────────────────────
LLM_EMBEDDING_URL=http://localhost:11434
LLM_EMBEDDING_MODEL=nomic-embed-text

# ── LLM Runtime ─────────────────────────────────────────────
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=2048
LLM_TIMEOUT=120
LLM_MAX_RETRIES=3

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_USER=edms
POSTGRES_PASSWORD=edms_secret
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=edms_ai

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Agent ────────────────────────────────────────────────────
COMPLEXITY_THRESHOLD=0.7
AGENT_MAX_ITERATIONS=10
AGENT_TIMEOUT=120.0
CACHE_TTL_SECONDS=300
MAX_CONTEXT_TOKENS=8000

# ── Feedback / RAG ───────────────────────────────────────────
RAG_REBUILD_INTERVAL_HOURS=24
ORCHESTRATOR_URL=http://localhost:8002
FEEDBACK_PORT=8003

# ── Monitoring ───────────────────────────────────────────────
GRAFANA_PASSWORD=admin

# ── CORS ─────────────────────────────────────────────────────
ALLOWED_ORIGINS=*
