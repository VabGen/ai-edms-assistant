# ═══════════════════════════════════════════════════════════════════════════
# EDMS AI Assistant — Environment Configuration Template
# ═══════════════════════════════════════════════════════════════════════════


# ═══════════════════════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────────────────────
# APP
# ───────────────────────────────────────────────────────────────────────────
# Окружение: development, staging, production
ENVIRONMENT=development

# Порты сервисов
API_PORT=8000
FEEDBACK_PORT=8002
ORCHESTRATOR_PORT=8000
PROMETHEUS_PORT=9090
GRAFANA_PORT=3000

# Логирование: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Hot-reload (только для разработки!)
RELOAD=false

# Часовой пояс (IANA timezone)
TIMEZONE=Europe/Moscow

# CORS разрешённые origin (через запятую или *)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080

# ───────────────────────────────────────────────────────────────────────────
# SECURITY
# ───────────────────────────────────────────────────────────────────────────
# GENERATE: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# ───────────────────────────────────────────────────────────────────────────
# LLM MODELS (Ollama)
# ───────────────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://127.0.0.1:11434

# Модели для разных ролей агента
MODEL_NAME=llama3.2:latest
MODEL_PLANNER=llama3.2:latest
MODEL_RESEARCHER=llama3.2:latest
MODEL_EXECUTOR=llama3.2:latest
MODEL_REVIEWER=llama3.2:latest
MODEL_EXPLAINER=llama3.2:latest

# Runtime параметры LLM
LLM_TEMPERATURE=0.6
LLM_MAX_TOKENS=2048
LLM_TIMEOUT=120
LLM_MAX_RETRIES=3
LLM_REQUEST_TIMEOUT=120
LLM_STREAM_USAGE=false

# Внешние API ключи (опционально)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
LLM_API_KEY=

# ───────────────────────────────────────────────────────────────────────────
# EMBEDDING
# ───────────────────────────────────────────────────────────────────────────
EMBEDDING_URL=http://model-embedding.shared.du.iba/v1
EMBEDDING_MODEL=embedding-model
EMBEDDING_DIM=1536
EMBEDDING_TIMEOUT=120
EMBEDDING_MAX_RETRIES=3
EMBEDDING_REQUEST_TIMEOUT=120
EMBEDDING_CTX_LENGTH=8191
EMBEDDING_CHUNK_SIZE=1000
EMBEDDING_MAX_RETRIES_PER_REQUEST=6

# FAISS индекс (fallback если Qdrant недоступен)
FAISS_INDEX_PATH=/tmp/edms_rag_faiss.pkl

# ───────────────────────────────────────────────────────────────────────────
# EDMS (Enterprise Document Management System)
# ───────────────────────────────────────────────────────────────────────────
EDMS_BASE_URL=http://127.0.0.1:8098
EDMS_TIMEOUT=120

# ───────────────────────────────────────────────────────────────────────────
# POSTGRES
# ───────────────────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-secure-password-change-in-production
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=edms

# URLs для разных целей (авто-генерация если пустые)
DATABASE_URL=
CHECKPOINT_DB_URL=
SQL_DB_URL=

# ───────────────────────────────────────────────────────────────────────────
# REDIS
# ───────────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_URL=

# TTL (в секундах)
CACHE_TTL_SECONDS=3600
CACHE_TTL_READ=300

# ───────────────────────────────────────────────────────────────────────────
# QDRANT (Vector DB)
# ───────────────────────────────────────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_URL=http://localhost:6333
QDRANT_PORT=6333
QDRANT_API_KEY=

# ───────────────────────────────────────────────────────────────────────────
# MCP (Model Context Protocol)
# ───────────────────────────────────────────────────────────────────────────
MCP_HOST=0.0.0.0
MCP_PORT=8001
MCP_URL=http://localhost:8001
MCP_WORKERS=1

# ───────────────────────────────────────────────────────────────────────────
# ORCHESTRATOR
# ───────────────────────────────────────────────────────────────────────────
ORCHESTRATOR_WORKERS=2
FEEDBACK_API_URL=http://localhost:8002
FEEDBACK_COLLECTOR_PORT=8002
FEEDBACK_WORKERS=1

# ───────────────────────────────────────────────────────────────────────────
# MEMORY
# ───────────────────────────────────────────────────────────────────────────
MEMORY_SHORT_TERM_MAX_TOKENS=8000
MEMORY_MEDIUM_TERM_TTL=3600

# ───────────────────────────────────────────────────────────────────────────
# FILE UPLOAD
# ───────────────────────────────────────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50
ALLOWED_FILE_EXTENSIONS=.docx,.doc,.pdf,.txt,.rtf,.xlsx,.xls,.pptx

# ───────────────────────────────────────────────────────────────────────────
# AGENT
# ───────────────────────────────────────────────────────────────────────────
AGENT_MAX_ITERATIONS=10
AGENT_MAX_CONTEXT_MESSAGES=20
AGENT_TIMEOUT=120.0
AGENT_ENABLE_TRACING=false
AGENT_LOG_LEVEL=INFO
AGENT_MAX_RETRIES=3
SETTINGS_PANEL_SHOW_TECHNICAL=false

# ───────────────────────────────────────────────────────────────────────────
# RAG
# ───────────────────────────────────────────────────────────────────────────
RAG_BATCH_SIZE=20
RAG_CHUNK_SIZE=1200
RAG_CHUNK_OVERLAP=300
RAG_EMBEDDING_BATCH_SIZE=10
RAG_COLLECTION_SUCCESSFUL=successful_dialogs
RAG_COLLECTION_ANTI=anti_examples
RAG_SIMILARITY_TOP_K=5
RAG_UPDATE_HOUR=3
RAG_UPDATE_MINUTE=0
CHROMA_PERSIST_DIR=./chroma_db

# ───────────────────────────────────────────────────────────────────────────
# RATE LIMITING
# ───────────────────────────────────────────────────────────────────────────
RATE_LIMIT_MAX_REQUESTS=10
RATE_LIMIT_WINDOW_SECONDS=60

# ───────────────────────────────────────────────────────────────────────────
# LOGGING
# ───────────────────────────────────────────────────────────────────────────
LOGGING_LEVEL=INFO
LOGGING_FORMAT=%(asctime)s [%(levelname)s] %(name)s: %(message)s
LOGGING_INCLUDE_TRACE_ID=true

# ───────────────────────────────────────────────────────────────────────────
# TELEMETRY & MONITORING
# ───────────────────────────────────────────────────────────────────────────
TELEMETRY_ENABLED=false
TELEMETRY_ENDPOINT=
HEALTH_CHECK_ENABLED=true

# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-in-production

# ───────────────────────────────────────────────────────────────────────────
# LANGSMITH (Optional Tracing)
# ───────────────────────────────────────────────────────────────────────────
LANGSMITH_TRACING=false
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=edms_ai_assistant

# ───────────────────────────────────────────────────────────────────────────
# SAFETY (New Architecture)
# ───────────────────────────────────────────────────────────────────────────
SAFETY_INPUT_FILTER=true
SAFETY_OUTPUT_FILTER=true
SAFETY_CONSTITUTIONAL_CHECK=false

# ───────────────────────────────────────────────────────────────────────────
# CACHE / PERFORMANCE
# ───────────────────────────────────────────────────────────────────────────
CHAT_CACHE_ENABLED=true
CHAT_CACHE_TTL_S=300

# ───────────────────────────────────────────────────────────────────────────
# SCHEDULER (Background Tasks)
# ───────────────────────────────────────────────────────────────────────────
RAG_REBUILD_HOUR=3
ORCHESTRATOR_URL=http://localhost:8000