# =============================================================================
# EDMS AI Assistant — .env
# =============================================================================

# =============================================================================
# LLM — Языковая модель (генерация)
# =============================================================================

# OpenAI-compatible endpoint (собственный деплой или прокси)
LLM__GENERATIVE=https://api.proxyapi.ru/openai/v1
LLM__GENERATIVE_MODEL=gpt-4o-mini
OPENAI_API_KEY=sk-peQ4dbtr20yWOrae82lbPjXNqFl7pvaO

#LLM__GENERATIVE=http://model-generative.shared.du.iba/v1
#LLM__GENERATIVE_MODEL=generative-model
LLM_API_KEY=

# Модель эмбеддингов
LLM__EMBEDDING=http://model-embedding.shared.du.iba/v1
LLM__EMBEDDING_MODEL=embedding-model

# =============================================================================
# LLM Runtime — параметры запросов к модели
# =============================================================================

LLM_TEMPERATURE=0.6
LLM_MAX_TOKENS=4096
# Общий таймаут сессии
LLM_TIMEOUT=90
LLM_MAX_RETRIES=3
# Таймаут одного HTTP-запроса
LLM_REQUEST_TIMEOUT=120
LLM_STREAM_USAGE=true
# LLM_DEFAULT_HEADERS={"X-Custom-Header": "value"}
# LLM_DEFAULT_QUERY=param=value

# =============================================================================
# Embedding Runtime
# =============================================================================

EMBEDDING_TIMEOUT=120
EMBEDDING_MAX_RETRIES=3
EMBEDDING_REQUEST_TIMEOUT=120
# EMBEDDING_DEFAULT_HEADERS={"X-Custom-Header": "value"}
# EMBEDDING_DEFAULT_QUERY=param=value
# Максимальная длина контекста для модели эмбеддингов
EMBEDDING_CTX_LENGTH=8191
# Размер чанка текста при индексировании
EMBEDDING_CHUNK_SIZE=1000
EMBEDDING_MAX_RETRIES_PER_REQUEST=6

# =============================================================================
# EDMS Backend (chancellor-next REST API)
# =============================================================================

CHANCELLOR_NEXT_BASE_URL=http://127.0.0.1:8098
# Таймаут HTTP-запросов к EDMS API
EDMS_TIMEOUT=120

# =============================================================================
# Vector Store (ChromaDB)
# =============================================================================

CHROMA_PERSIST_DIR=./chroma_db

# =============================================================================
# PostgreSQL — LangGraph Checkpointer + SQL DB
# =============================================================================

CHECKPOINT_DB_URL=postgresql://postgres:password@localhost:5432/edms_ai
SQL_DB_URL=postgresql://postgres:password@localhost:5432/edms_ai

# =============================================================================
# Redis — кэш сессий / очередей
# =============================================================================

REDIS_URL=redis://127.0.0.1:6379/0

# =============================================================================
# FastAPI Application
# =============================================================================

API_PORT=8000
DEBUG=true
# development | staging | production
ENVIRONMENT=development

# =============================================================================
# Agent
# =============================================================================

AGENT_ENABLE_TRACING=true
AGENT_LOG_LEVEL=INFO
AGENT_MAX_RETRIES=3

# =============================================================================
# Logging
# =============================================================================

LOGGING_LEVEL=DEBUG
LOGGING_FORMAT=%(asctime)s [%(levelname)s] %(name)s: %(message)s

# =============================================================================
# Telemetry / OpenTelemetry (OTLP экспортёр)
# =============================================================================

TELEMETRY_ENABLED=false
TELEMETRY_ENDPOINT=http://127.0.0.1:4318

# =============================================================================
# LangSmith Tracing (опционально — для дебага цепочек агента)
# =============================================================================

# LANGSMITH_TRACING=true
# LANGSMITH_ENDPOINT=https://api.smith.langchain.com
# LANGSMITH_API_KEY=lsv2_pt_...
# LANGSMITH_PROJECT=edms-ai-assistant

# =============================================================================
# RAG — Retrieval-Augmented Generation
# =============================================================================

RAG_BATCH_SIZE=20
RAG_CHUNK_SIZE=1200
RAG_CHUNK_OVERLAP=300
RAG_EMBEDDING_BATCH_SIZE=10

# =============================================================================
# Frontend / CORS
# =============================================================================

REACT_APP_API_URL=http://localhost:8000
